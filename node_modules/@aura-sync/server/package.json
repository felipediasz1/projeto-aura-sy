{
  "name": "@aura-sync/server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "aura-sync-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch && nodemon dist/index.js",
    "start": "node dist/index.js",
    "package": "npm run build && pkg . --targets node18-win-x64 --output dist/AuraSync_Server.exe",
    "deploy": "npm run build && node dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "typescript": "^4.9.5",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "nodemon": "^3.0.0",
    "pkg": "^5.8.0"
  } 
}