{
  "name": "@aura-sync/agent",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "aura-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pkg": "pkg . --targets node18-win-x64 --output dist/aura-sync-agent.exe",
    "package": "npm run build && npm run pkg"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "form-data": "^4.0.0",
    "micromatch": "^4.0.5"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/micromatch": "^4.0.7",
    "@types/node": "^20.0.0",
    "pkg": "^5.8.0",
    "typescript": "^4.9.5"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/form-data/**/*",
      "node_modules/axios/**/*",
      "node_modules/fast-deep-equal/**/*"
    ]
  }
}
