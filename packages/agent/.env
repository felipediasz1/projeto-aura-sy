# Exemplo de configuração para o Agente Aura Sync
# Copie este arquivo para .env na pasta do agente

# URL do servidor central
AURA_SERVER_URL=http://localhost:3000

# Token de autenticação exclusivo para este agente
AURA_TOKEN=valid-token

# Caminhos para scan (separados por vírgula)
AURA_SCAN_PATHS=./documents,./data

# ID da empresa
AURA_COMPANY_ID=1

# ID da máquina
AURA_MACHINE_ID=m1